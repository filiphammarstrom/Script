# Kopiera till .env och fyll i din nyckel.
ANTHROPIC_API_KEY=

# Valfritt: byt modell. Default är claude-sonnet-4-6.
# För svårare attribuering/tolkning kan claude-opus-4-8 användas.
# SCRIPT_MODEL=claude-sonnet-4-6

# Ljudtranskribering (molntjänst med diarisering). Krävs för ljudfil-input.
ASSEMBLYAI_API_KEY=
# Valfritt: byt transkriberings-backend. Default är assemblyai.
# TRANSCRIBE_BACKEND=assemblyai

# Valfritt: Groq – billigaste moln-transkriberingen (~0,04 $/timme, ingen diarisering).
# GROQ_API_KEY=
# GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo

# Valfritt: Deepgram – nästan lika billigt som Groq, men MED diarisering (talar-etiketter).
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2

# Valfritt: stäng av tystnadsklippningen före moln-uppladdning (på som standard).
# TRANSCRIBE_TRIM_SILENCE=0
